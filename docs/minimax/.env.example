# MiniMax API 环境变量配置示例
# 复制此文件为 .env 并填入实际的值

# MiniMax API 密钥（必需）
# 从 https://www.minimaxi.com/ 控制台获取
MINIMAX_API_KEY=your_minimax_api_key_here

# MiniMax Group ID（必需）
# 从 MiniMax 控制台获取
MINIMAX_GROUP_ID=your_group_id_here

# MiniMax API 基础 URL（可选，默认为 https://api.minimax.chat）
MINIMAX_BASE_URL=https://api.minimax.chat

# 使用说明：
# 1. Windows 系统：
#    setx MINIMAX_API_KEY "your_api_key"
#    setx MINIMAX_GROUP_ID "your_group_id"
#
# 2. Linux/Mac 系统：
#    export MINIMAX_API_KEY="your_api_key"
#    export MINIMAX_GROUP_ID="your_group_id"
#
# 3. IDEA 配置：
#    Run -> Edit Configurations -> Environment variables
#    添加：MINIMAX_API_KEY=xxx;MINIMAX_GROUP_ID=xxx
